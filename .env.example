# DATABASE_URL is OPTIONAL when deployed on Netlify: installing @netlify/database
# (already in package.json) auto-provisions a Postgres instance and injects its
# connection string automatically at deploy time. Only set this manually if you
# want to point at your own Postgres/Neon instance instead, or for local dev
# outside `netlify dev`.
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/carto?sslmode=require

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# CORS - set to your deployed site URL in production
ALLOWED_ORIGIN=*
