# Neon PostgreSQL connection string.
# Get one free at https://neon.tech (or via the Neon integration in the
# Vercel dashboard: Storage tab -> Connect Database -> Neon).
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/carto?sslmode=require

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# CORS - set to your deployed Vercel URL in production
ALLOWED_ORIGIN=*

# Email - used for OTP verification codes and password reset codes.
# If neither option below is configured, OTP codes are returned directly
# in the API response instead of emailed - useful for testing, but NOT
# something you want left on for a real production launch.

# Option A (recommended if you don't own a domain): Gmail SMTP.
# 1. Enable 2-Step Verification on your Google account.
# 2. Create an "App Password" at myaccount.google.com/apppasswords
# 3. Use that 16-character password below (not your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=Carto <youraddress@gmail.com>

# Option B: Resend (simpler setup, but their free tier can only send to
# the email you signed up with, unless you verify your own domain).
RESEND_API_KEY=
