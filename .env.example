# Neon PostgreSQL connection string.
# Get one free at https://neon.tech (or via the Neon integration in the
# Vercel dashboard: Storage tab -> Connect Database -> Neon).
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/carto?sslmode=require

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# CORS - set to your deployed Vercel URL in production
ALLOWED_ORIGIN=*

# Email (Resend) - used for OTP verification codes and password reset codes.
# Get a free API key at https://resend.com (no credit card required).
# If left unset, OTP codes are returned directly in the API response
# instead of emailed - useful for testing before you set this up, but
# NOT something you want left on for a real production launch.
RESEND_API_KEY=
EMAIL_FROM=Carto <onboarding@resend.dev>
